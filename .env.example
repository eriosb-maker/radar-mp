# Copia este archivo a .env y completa los valores

# Ticket API Mercado Público (obtener en api.mercadopublico.cl)
CHILECOMPRA_TICKET=TU-TICKET-AQUI

# API Key Anthropic (opcional — para análisis IA avanzado)
ANTHROPIC_API_KEY=sk-ant-...

# Email para alertas (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASSWORD=tu-app-password
FROM_EMAIL=radar@tudominio.cl
